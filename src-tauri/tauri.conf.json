{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Deployer",
  "version": "0.1.0",
  "identifier": "ai.openclaw.deployer",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaw 部署器",
        "width": 1440,
        "height": 960,
        "minWidth": 1160,
        "minHeight": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
